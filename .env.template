# ─── Yirra Care Agents — Required API Keys ───────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to git — it contains secrets.

# ── OpenAI ────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-YOUR_KEY_HERE
OPENAI_MODEL=gpt-4.1-mini

# ── Sender / Company Info ─────────────────────────────────────────
SENDER_NAME=Greg Gomez
SENDER_TITLE=CEO | Founder
SENDER_EMAIL=greg@yirracare.com.au
SENDER_PHONE=0474 525 811
COMPANY_NAME=Yirra Care
COMPANY_WEBSITE=https://yirracare.com.au
DEFAULT_LOCATIONS=Brisbane North, Moreton Bay, Redcliffe, Clontarf, Rothwell, Morayfield, Caboolture

# ── Google Custom Search (optional, improves prospect discovery) ──
GOOGLE_API_KEY=
GOOGLE_CSE_ID=

# ── File Paths (usually don't need to change) ─────────────────────
DATABASE_PATH=data/yirra_referrals.sqlite
GOOGLE_CLIENT_SECRET_FILE=client_secret.json
GOOGLE_TOKEN_FILE=token.json

# ── Pipeline Tuning ───────────────────────────────────────────────
MAX_CONTACTS_PER_QUERY=15
REQUEST_DELAY_SECONDS=1.5
MAX_DRAFTS_PER_RUN=20
